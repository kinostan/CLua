{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "rootDir": "src", // Note: If adding paths outside ./src, you may need to adjust or remove rootDir
    "outDir": "build",
    "types": [],

    "paths": {
      "#root/*": ["./src/*"],
      "#config/*": ["./src/config/*"],
      "#clua/*": ["./src/clua/*"],
      "#common/*": ["./src/common/*"]
    },

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "noEmitOnError": true
  },
  
  "include": [
    "src/**/*"
  ]
}
